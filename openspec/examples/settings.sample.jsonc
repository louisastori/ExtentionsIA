{
  // Profil utilisé par défaut au lancement de l'extension.
  "esctentionialocal.defaultProfileId": "openai-gpt-5.3-codex",

  // Modes: chat | edit | run | agent
  "esctentionialocal.defaultMode": "chat",

  // Politique de boucle par défaut.
  "esctentionialocal.agent.loopMode": "until_goal_or_limits",
  "esctentionialocal.agent.maxIterations": 12,
  "esctentionialocal.agent.maxToolCalls": 30,
  "esctentionialocal.agent.timeBudgetMs": 600000,
  "esctentionialocal.agent.maxConsecutiveFailures": 3,
  "esctentionialocal.agent.autoApproveReadOnlyTools": true,
  "esctentionialocal.agent.autoApproveWorkspaceEdits": false,
  "esctentionialocal.agent.autoApproveTerminal": false,
  "esctentionialocal.agent.commandAllowList": [
    "npm test",
    "npm run test",
    "npm run lint",
    "npm run build",
    "pnpm test",
    "pnpm lint",
    "pnpm build"
  ],
  "esctentionialocal.agent.commandDenyList": [
    "rm -rf /",
    "git reset --hard",
    "del /s /q"
  ],

  // Profils de providers.
  "esctentionialocal.providers": {
    "version": 1,
    "activeProfileId": "openai-gpt-5.3-codex",
    "profiles": [
      {
        "id": "openai-gpt-5.3-codex",
        "label": "OpenAI GPT-5.3-Codex",
        "providerType": "openai",
        "model": "gpt-5.3-codex",
        "apiKeySecretRef": "esctentionialocal.openai.apiKey",
        "temperature": 0.1,
        "maxOutputTokens": 32000,
        "reasoningEffort": "high",
        "capabilities": {
          "streaming": true,
          "toolCalling": true,
          "jsonMode": true,
          "vision": true,
          "reasoningEffort": true,
          "parallelToolCalls": true
        }
      },
      {
        "id": "openai-gpt-4.1",
        "label": "OpenAI GPT-4.1",
        "providerType": "openai",
        "model": "gpt-4.1",
        "apiKeySecretRef": "esctentionialocal.openai.apiKey",
        "temperature": 0.2,
        "maxOutputTokens": 16000,
        "capabilities": {
          "streaming": true,
          "toolCalling": true,
          "jsonMode": true,
          "vision": true,
          "reasoningEffort": true
        }
      },
      {
        "id": "anthropic-sonnet",
        "label": "Anthropic Claude Sonnet",
        "providerType": "anthropic",
        "model": "claude-sonnet-4-0",
        "apiKeySecretRef": "esctentionialocal.anthropic.apiKey",
        "temperature": 0.2,
        "maxOutputTokens": 16000,
        "capabilities": {
          "streaming": true,
          "toolCalling": true,
          "jsonMode": true,
          "vision": true,
          "reasoningEffort": false
        }
      },
      {
        "id": "ollama-qwen",
        "label": "Ollama Qwen Coder",
        "providerType": "ollama",
        "baseUrl": "http://localhost:11434",
        "model": "qwen2.5-coder:14b",
        "temperature": 0.1,
        "maxOutputTokens": 8192,
        "capabilities": {
          "streaming": true,
          "toolCalling": true,
          "jsonMode": false,
          "vision": false,
          "reasoningEffort": false
        }
      },
      {
        "id": "lmstudio-local",
        "label": "LM Studio Local",
        "providerType": "openai-compatible",
        "baseUrl": "http://localhost:1234/v1",
        "model": "local-model",
        "apiKeySecretRef": "esctentionialocal.lmstudio.apiKey",
        "temperature": 0.1,
        "maxOutputTokens": 8192,
        "capabilities": {
          "streaming": true,
          "toolCalling": true,
          "jsonMode": true,
          "vision": false,
          "reasoningEffort": false
        }
      }
    ]
  }
}
