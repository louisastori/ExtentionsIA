{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://esctentionialocal.dev/schemas/webview-protocol.schema.json",
  "title": "esctentionIALocal Webview Protocol",
  "oneOf": [
    {
      "$ref": "#/$defs/uiReady"
    },
    {
      "$ref": "#/$defs/uiChatSubmit"
    },
    {
      "$ref": "#/$defs/uiAgentStart"
    },
    {
      "$ref": "#/$defs/uiAgentControl"
    },
    {
      "$ref": "#/$defs/uiApprovalResponse"
    },
    {
      "$ref": "#/$defs/uiUpsertProfile"
    },
    {
      "$ref": "#/$defs/hostSessionState"
    },
    {
      "$ref": "#/$defs/hostStreamDelta"
    },
    {
      "$ref": "#/$defs/hostToolProposed"
    },
    {
      "$ref": "#/$defs/hostToolResult"
    },
    {
      "$ref": "#/$defs/hostRunStatus"
    },
    {
      "$ref": "#/$defs/hostError"
    }
  ],
  "$defs": {
    "baseMessage": {
      "type": "object",
      "required": [
        "type",
        "requestId",
        "timestamp"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "uiReady": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMessage"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "ui.ready"
            },
            "requestId": {
              "type": "string"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "webviewVersion": {
                  "type": "string"
                }
              }
            }
          }
        }
      ]
    },
    "uiChatSubmit": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMessage"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "ui.chat.submit"
            },
            "requestId": {
              "type": "string"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "text",
                "mode"
              ],
              "properties": {
                "text": {
                  "type": "string"
                },
                "mode": {
                  "type": "string",
                  "enum": [
                    "chat",
                    "edit",
                    "run",
                    "agent"
                  ]
                },
                "profileId": {
                  "type": "string"
                },
                "model": {
                  "type": "string"
                }
              }
            }
          }
        }
      ]
    },
    "uiAgentStart": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMessage"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "ui.agent.start"
            },
            "requestId": {
              "type": "string"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "payload": {
              "$ref": "agent-run.schema.json#/$defs/agentRunRequest"
            }
          }
        }
      ]
    },
    "uiAgentControl": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMessage"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "enum": [
                "ui.agent.pause",
                "ui.agent.resume",
                "ui.agent.stop"
              ]
            },
            "requestId": {
              "type": "string"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "runId"
              ],
              "properties": {
                "runId": {
                  "type": "string"
                }
              }
            }
          }
        }
      ]
    },
    "uiApprovalResponse": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMessage"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "ui.tool.approval"
            },
            "requestId": {
              "type": "string"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "approvalId",
                "decision"
              ],
              "properties": {
                "approvalId": {
                  "type": "string"
                },
                "decision": {
                  "type": "string",
                  "enum": [
                    "approved",
                    "rejected"
                  ]
                }
              }
            }
          }
        }
      ]
    },
    "uiUpsertProfile": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMessage"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "ui.settings.upsertProfile"
            },
            "requestId": {
              "type": "string"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "payload": {
              "$ref": "provider-config.schema.json#/$defs/providerProfile"
            }
          }
        }
      ]
    },
    "hostSessionState": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMessage"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "host.session.state"
            },
            "requestId": {
              "type": "string"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "payload": {
              "type": "object"
            }
          }
        }
      ]
    },
    "hostStreamDelta": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMessage"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "host.stream.delta"
            },
            "requestId": {
              "type": "string"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "runId",
                "textDelta"
              ],
              "properties": {
                "runId": {
                  "type": "string"
                },
                "textDelta": {
                  "type": "string"
                }
              }
            }
          }
        }
      ]
    },
    "hostToolProposed": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMessage"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "host.tool.proposed"
            },
            "requestId": {
              "type": "string"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "payload": {
              "$ref": "tool-runtime.schema.json#/$defs/toolCall"
            }
          }
        }
      ]
    },
    "hostToolResult": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMessage"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "host.tool.result"
            },
            "requestId": {
              "type": "string"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "payload": {
              "$ref": "tool-runtime.schema.json#/$defs/toolResult"
            }
          }
        }
      ]
    },
    "hostRunStatus": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMessage"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "host.run.status"
            },
            "requestId": {
              "type": "string"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "payload": {
              "$ref": "agent-run.schema.json#/$defs/runStatusEvent"
            }
          }
        }
      ]
    },
    "hostError": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMessage"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "host.error"
            },
            "requestId": {
              "type": "string"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "code",
                "message"
              ],
              "properties": {
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      ]
    }
  }
}
